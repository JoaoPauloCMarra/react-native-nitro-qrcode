{
  "name": "react-native-nitro-qrcode-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "setup": "node scripts/setup.js",
    "publish-package": "bun scripts/publish.js",
    "publish-package:dry-run": "bun scripts/publish.js --dry-run",
    "build": "turbo run build",
    "dev": "bun run example:start",
    "check": "bun run lint && bun run typecheck && bun run test:coverage && bun run test:cpp && bun run build && bun run example:check",
    "lint": "turbo run lint",
    "clean": "turbo run clean",
    "codegen": "turbo run codegen",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:unit": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "test:cpp": "turbo run test:cpp --filter=react-native-nitro-qrcode",
    "test:cpp:sanitize": "node scripts/test-cpp-sanitize.js",
    "benchmark:cpp": "node scripts/benchmark-cpp.js",
    "example:lint": "bun run --cwd apps/example lint",
    "example:doctor": "bun run --cwd apps/example doctor",
    "example:check": "bun run example:lint && bun run example:doctor",
    "example:start": "bun run --cwd apps/example start",
    "example:web": "bun run --cwd apps/example web",
    "example:ios": "bun run --cwd apps/example ios",
    "example:android": "bun run --cwd apps/example android",
    "example:logs:ios": "xcrun simctl spawn booted log stream --style compact --predicate 'process == \"NitroQRCodeExample\" OR eventMessage CONTAINS \"ReactNativeJS\" OR eventMessage CONTAINS \"NitroQRCode\"'",
    "example:logs:android": "adb logcat ReactNativeJS:I NitroQRCodeOnLoad:I NitroModules:I AndroidRuntime:E '*:S'",
    "example:prebuild": "bun run --cwd apps/example prebuild",
    "example:prebuild:clean": "bun run --cwd apps/example prebuild:clean"
  },
  "devDependencies": {
    "@swc/core": "^1.15.26",
    "@swc/jest": "^0.2.39",
    "@react-native/babel-preset": "^0.83.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "~19.2.0",
    "eslint-config-expo-magic": "^2.4.0",
    "jest": "^30.3.0",
    "nitrogen": "0.35.4",
    "qrcode": "^1.5.4",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-builder-bob": "^0.40.18",
    "react-native-nitro-modules": "0.35.4",
    "react-test-renderer": "19.2.0",
    "rimraf": "^6.0.1",
    "ts-jest": "^29.4.9",
    "turbo": "^2.7.3",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-nitro-modules": "0.35.4",
    "@types/react": "~19.2.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "bun": ">=1.3.11"
  },
  "packageManager": "bun@1.3.11"
}
